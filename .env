# ───────────────────────────────
# Boss直聘 账号 & 会话
# ───────────────────────────────
# 登录后从浏览器 DevTools 中复制 cookie（用于免登录请求）
BOSS_COOKIE=

# ───────────────────────────────
# 搜索目标 URL（职位列表入口）
# ───────────────────────────────
BOSS_JOBS_URL=https://www.zhipin.com/web/geek/jobs?ka=header-jobs

# ───────────────────────────────
# 筛选条件（对应页面筛选栏）
# ───────────────────────────────
# 城市（中文或城市 code，e.g. 郑州 / 101180101）
FILTER_CITY=郑州

# 求职类型（全职 / 兼职 / 实习）
FILTER_JOB_TYPE=全职

# 薪资范围（单位：K）
FILTER_SALARY_MIN=8
FILTER_SALARY_MAX=20

# 工作经验（不限 / 应届生 / 1年以内 / 1-3年 / 3-5年 / 5-10年 / 10年以上）
FILTER_EXPERIENCE=不限

# 学历要求（不限 / 大专 / 本科 / 硕士 / 博士）
FILTER_EDUCATION=不限

# 公司行业（逗号分隔，留空表示不限，e.g. 互联网,人工智能）
FILTER_INDUSTRY=

# 公司规模（不限 / 0-20人 / 20-99人 / 100-499人 / 500-999人 / 1000-9999人 / 10000人以上）
FILTER_COMPANY_SCALE=

# 搜索关键词（职位名或技能关键词，逗号分隔）
FILTER_KEYWORDS=Python,AI

# ───────────────────────────────
# JD 匹配 —— 候选人背景描述（提供给 LLM 用于匹配判断）
# ───────────────────────────────
CANDIDATE_PROFILE=熟悉 Python，有 AI/LLM 应用开发经验，了解 Stable Diffusion

# ───────────────────────────────
# DeepSeek 大模型配置（LangChain ChatOpenAI）
# ───────────────────────────────
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ───────────────────────────────
# 投递行为控制
# ───────────────────────────────
# 每日最大投递数量（Boss直聘限制约 100 次/天）
MAX_DAILY_APPLY=50

# 每次投递之间的随机延迟范围（秒）
APPLY_DELAY_MIN=3
APPLY_DELAY_MAX=8

# 是否在投递前自动打招呼（true / false）
AUTO_GREET=true

# 打招呼消息模板（{position} 和 {company} 为占位符）
GREET_MESSAGE=您好，我对贵公司的{position}职位很感兴趣，期待进一步沟通！

# ───────────────────────────────
# 浏览器自动化（Playwright）
# ───────────────────────────────
# 无头模式运行（true / false）
HEADLESS=true

# 浏览器类型（chromium / firefox / webkit）
BROWSER_TYPE=chromium

# 页面加载超时（毫秒）
PAGE_TIMEOUT=30000

# ───────────────────────────────
# 结果持久化
# ───────────────────────────────
# 投递结果日志文件路径
LOG_FILE=./logs/deliver.log
